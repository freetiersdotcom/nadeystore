---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import ContactWidget from '~/components/widgets/Contact.astro';
import Features2 from '~/components/widgets/Features2.astro';

const metadata = {
  title: 'Contact — Nadey Naturel',
  description: 'Une question sur nos produits, une commande, ou un partenariat ? Contactez l\'équipe Nadey Naturel.',
};
---

<Layout metadata={metadata}>

  <HeroText
    tagline="Nous contacter"
    title="Une question ? Nous sommes là."
    subtitle="Que ce soit pour une question sur un produit, un problème de livraison ou une opportunité de partenariat — notre équipe vous répond en général sous 24 à 48 heures ouvrées."
  />

  <!-- ── Contact channels ────────────────────────────────────── -->
  <Features2
    title="Comment nous joindre"
    columns={3}
    items={[
      {
        title: 'E-mail',
        description:
          'Pour toute question générale, commande ou réclamation :<br/><a href="mailto:contact@nadeynaturel.com" class="text-primary hover:underline font-medium">contact@nadeynaturel.com</a>',
        icon: 'tabler:mail',
      },
      {
        title: 'WhatsApp',
        description:
          'Pour un suivi rapide de commande ou une question urgente :<br/><a href="https://wa.me/22900000000" class="text-primary hover:underline font-medium">+229 XX XX XX XX</a>',
        icon: 'tabler:brand-whatsapp',
      },
      {
        title: 'Adresse',
        description:
          'Nadey Naturel<br/>Cotonou, Bénin<br/><span class="text-muted text-xs">Retrait sur place non disponible pour le moment.</span>',
        icon: 'tabler:map-pin',
      },
    ]}
  />

  <!-- ── Contact form ────────────────────────────────────────── -->
  <ContactWidget
    id="formulaire"
    title="Envoyez-nous un message"
    subtitle="Remplissez ce formulaire et nous vous répondrons dans les plus brefs délais."
    inputs={[
      {
        type: 'text',
        name: 'name',
        label: 'Nom complet',
        placeholder: 'Votre nom',
        autocomplete: 'name',
      },
      {
        type: 'email',
        name: 'email',
        label: 'Adresse e-mail',
        placeholder: 'vous@exemple.com',
        autocomplete: 'email',
      },
    ]}
    textarea={{
      name: 'message',
      label: 'Message',
      placeholder: 'Décrivez votre question ou votre demande...',
      rows: 6,
    }}
    button="Envoyer le message"
    description="Vos informations ne seront jamais partagées avec des tiers. Consultez notre politique de confidentialité."
  />
  
  <!-- <a href='/confidentialite' class='text-primary hover:underline'>politique de confidentialité</a> -->

</Layout>
