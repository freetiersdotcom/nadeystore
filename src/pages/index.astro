---
import Layout from '~/layouts/PageLayout.astro';
import Hero2 from '~/components/widgets/Hero2.astro';
import Features from '~/components/widgets/Features.astro';
import Content from '~/components/widgets/Content.astro';
import Steps from '~/components/widgets/Steps.astro';
import Testimonials from '~/components/widgets/Testimonials.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'Nadey Naturel — Produits de santé naturelle du Bénin',
  description:
    'Découvrez nos produits de santé naturelle à base de plantes d\'Afrique de l\'Ouest. Moringa, gingembre, et bien plus — livrés partout en Europe et dans la diaspora.',
};
---

<Layout metadata={metadata}>

  <!-- ── Hero ──────────────────────────────────────────────── -->
  <Hero2
    tagline="100 % naturel · Origine Bénin"
    title="La nature de <span class='text-accent dark:text-accent highlight'>l'Afrique de l'Ouest</span>,<br class='hidden md:block' /> livrée chez vous."
    subtitle="Des plantes cultivées et transformées au Bénin, sélectionnées pour leurs bienfaits reconnus depuis des générations. Moringa, gingembre, baobab et plus — pour prendre soin de vous où que vous soyez."
    actions={[
      { variant: 'primary', text: 'Découvrir la boutique', href: '/fr/boutique', icon: 'tabler:shopping-cart' },
      { text: 'Notre histoire', href: '/a-propos' },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1556909114-f6e7ad7d3136?w=1200&q=80',
      alt: 'Plantes médicinales africaines — moringa et gingembre',
    }}
  />

  <!-- ── Trust strip ────────────────────────────────────────── -->
  <Features
    id="avantages"
    tagline="Pourquoi nous choisir"
    title="Des produits en qui vous pouvez avoir confiance"
    subtitle="Chaque produit est soigneusement sélectionné, transformé au Bénin et expédié directement à votre porte."
    columns={4}
    items={[
      {
        title: 'Ingrédients authentiques',
        description:
          'Plantes natives d\'Afrique de l\'Ouest, cueillies et transformées selon des méthodes traditionnelles éprouvées.',
        icon: 'tabler:leaf',
      },
      {
        title: 'Sans additifs',
        description:
          'Aucun conservateur artificiel, aucun arôme de synthèse. Ce que vous voyez sur l\'étiquette est tout ce qu\'il y a.',
        icon: 'tabler:shield-check',
      },
      {
        title: 'Livraison diaspora',
        description:
          'Expédition vers la France, la Belgique, le Royaume-Uni, le Canada et d\'autres destinations. Suivi inclus.',
        icon: 'tabler:world',
      },
      {
        title: 'Paiement sécurisé',
        description:
          'Paiement via FedaPay avec protection acheteur. Remboursement garanti sous 14 jours si vous n\'êtes pas satisfait.',
        icon: 'tabler:lock',
      },
    ]}
  />

  <!-- ── Featured products ──────────────────────────────────── -->
  <Content
    id="produits"
    tagline="Nos produits vedettes"
    title="Ce que la nature a de mieux à offrir"
    subtitle="Une sélection de produits phares, issus des plantes les plus prisées d'Afrique de l'Ouest."
    isReversed
    items={[
      {
        title: 'Moringa en poudre',
        description:
          'Surnommé « l\'arbre miracle », le moringa est l\'une des plantes les plus riches en nutriments connues. Notre poudre de feuilles séchées à froid conserve l\'intégralité de ses bienfaits.',
        icon: 'tabler:plant',
      },
      {
        title: 'Gingembre bio',
        description:
          'Racines de gingembre cultivées sans pesticides dans les terres argileuses du sud du Bénin. Idéal pour les infusions, les smoothies et la cuisine.',
        icon: 'tabler:flame',
      },
      {
        title: 'Poudre de baobab',
        description:
          'La pulpe de baobab contient six fois plus de vitamine C que l\'orange. Un complément naturel pour renforcer l\'immunité et favoriser la digestion.',
        icon: 'tabler:circle-plus',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1505576399279-565b52d4ac71?w=800&q=80',
      alt: 'Poudre de moringa et épices naturelles',
    }}
    callToAction={{
      text: 'Voir tous les produits',
      href: '/fr/boutique',
      icon: 'tabler:arrow-right',
    }}
  />

  <!-- ── Story / About strip ────────────────────────────────── -->
  <Content
    tagline="Notre histoire"
    title="Nés au Bénin, pour la diaspora"
    content={`
      <p>Pendant des siècles, les familles d'Afrique de l'Ouest ont soigné leur santé avec ce que la terre leur offrait. Le moringa pour l'énergie, le gingembre contre le rhume, le baobab pour la vitalité.</p>
      <p class="mt-4">Nadey Naturel est né d'un constat simple : la diaspora africaine en Europe cherche ces produits de qualité, mais les trouve rarement authentiques ou accessibles. Nous avons créé un pont direct entre les producteurs béninois et vos tables.</p>
      <p class="mt-4 font-medium">Chaque commande soutient une filière locale et vous apporte un morceau d'Afrique de l'Ouest.</p>
    `}
    items={[
      {
        title: 'Producteurs locaux',
        description: 'Partenariats directs avec des agriculteurs familiaux dans les régions du Mono et du Couffo.',
        icon: 'tabler:users',
      },
      {
        title: 'Transformation artisanale',
        description: 'Séchage, broyage et conditionnement réalisés au Bénin pour préserver les nutriments.',
        icon: 'tabler:heart-handshake',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1542601906990-b4d3fb778b09?w=800&q=80',
      alt: 'Femme béninoise traitant des plantes médicinales',
    }}
    callToAction={{
      text: 'En savoir plus',
      href: '/a-propos',
      icon: 'tabler:arrow-right',
    }}
  />

  <!-- ── How it works ───────────────────────────────────────── -->
  <Steps
    id="comment-ca-marche"
    tagline="Simple et rapide"
    title="Commander en 3 étapes"
    items={[
      {
        title: 'Parcourez la boutique',
        description:
          'Explorez notre catalogue de produits naturels. Chaque fiche produit détaille les ingrédients, les bienfaits et les conseils d\'utilisation.',
        icon: 'tabler:search',
      },
      {
        title: 'Passez votre commande',
        description:
          'Ajoutez vos produits au panier, renseignez votre adresse de livraison et payez en toute sécurité via FedaPay — carte ou mobile money acceptés.',
        icon: 'tabler:shopping-cart',
      },
      {
        title: 'Recevez chez vous',
        description:
          'Votre commande est préparée au Bénin et expédiée vers votre adresse en Europe ou ailleurs dans la diaspora. Confirmation et suivi par e-mail.',
        icon: 'tabler:package',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1586528116311-ad8dd3c8310d?w=800&q=80',
      alt: 'Colis de produits naturels prêt à l\'expédition',
    }}
  />

  <!-- ── Testimonials ───────────────────────────────────────── -->
  <Testimonials
    id="avis"
    tagline="Ils nous font confiance"
    title="Ce que disent nos clients"
    subtitle="Des membres de la diaspora qui ont redécouvert les saveurs et les bienfaits de leurs racines."
    testimonials={[
      {
        testimonial:
          'La poudre de moringa est incroyable. Je l\'ajoute à mon smoothie du matin et j\'ai l\'impression de retrouver l\'énergie de mes 20 ans. La qualité est vraiment au rendez-vous.',
        name: 'Aminata D.',
        job: 'Paris, France',
        image: { src: 'https://images.unsplash.com/photo-1531746020798-e6953c6e8e04?w=80&q=80', alt: 'Aminata D.' },
      },
      {
        testimonial:
          'Enfin du vrai gingembre béninois ! Pas cette poudre fade qu\'on trouve en supermarché. La livraison en Belgique s\'est faite sans problème et l\'emballage était soigné.',
        name: 'Kofi M.',
        job: 'Bruxelles, Belgique',
        image: { src: 'https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=80&q=80', alt: 'Kofi M.' },
      },
      {
        testimonial:
          'Je commande pour toute la famille. Ma mère dit que ça lui rappelle ce que sa grand-mère utilisait. C\'est le plus beau des compliments pour un produit naturel.',
        name: 'Fatou B.',
        job: 'Londres, Royaume-Uni',
        image: { src: 'https://images.unsplash.com/photo-1589156288859-f0cb0d82b065?w=80&q=80', alt: 'Fatou B.' },
      },
    ]}
    callToAction={{
      text: 'Voir la boutique',
      href: '/fr/boutique',
    }}
  />

  <!-- ── Final CTA ──────────────────────────────────────────── -->
  <CallToAction
    tagline="Prêt à essayer ?"
    title="Votre première commande vous attend"
    subtitle="Livraison vers la France, la Belgique, le Royaume-Uni, le Canada et bien d'autres destinations. Satisfaction garantie ou remboursé."
    actions={[
      { variant: 'primary', text: 'Découvrir la boutique', href: '/fr/boutique', icon: 'tabler:shopping-cart' },
    ]}
  />

</Layout>
