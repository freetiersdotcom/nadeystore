---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import Content from '~/components/widgets/Content.astro';
import Features2 from '~/components/widgets/Features2.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'À propos — Nadey Naturel',
  description:
    'Découvrez l\'histoire de Nadey Naturel, notre mission et notre engagement envers les producteurs béninois et la diaspora africaine.',
};
---

<Layout metadata={metadata}>

  <HeroText
    tagline="Notre histoire"
    title="Nés de la terre, pensés pour la diaspora"
    subtitle="Nadey Naturel est une entreprise béninoise qui croit que les savoirs ancestraux sur les plantes médicinales d'Afrique de l'Ouest méritent d'être partagés avec le monde entier — à commencer par ceux qui en sont issus."
  />

  <!-- ── Mission ─────────────────────────────────────────────── -->
  <Content
    tagline="Notre mission"
    title="Reconnecter la diaspora à ses racines naturelles"
    content={`
      <p>Des millions de personnes originaires d'Afrique de l'Ouest vivent en Europe, au Canada et ailleurs dans le monde. Beaucoup ont grandi avec des remèdes et des saveurs qui font partie de leur identité — le thé au gingembre de leur grand-mère, la poudre de moringa dans le riz, le baobab mélangé au lait.</p>
      <p class="mt-4">En arrivant en Europe, retrouver ces produits authentiques relève souvent du parcours du combattant. Les épiceries africaines proposent des versions d'importation dont la traçabilité est floue. Les grandes surfaces vendent des substituts qui n'ont de commun que le nom.</p>
      <p class="mt-4">Nadey Naturel a été créé pour changer ça. Nous travaillons directement avec des producteurs du Bénin pour vous apporter des produits dont vous connaissez l'origine à la parcelle près.</p>
    `}
    isReversed
    image={{
      src: 'https://images.unsplash.com/photo-1605020420620-20c943cc4669?w=800&q=80',
      alt: 'Marché de plantes médicinales au Bénin',
    }}
  />

  <!-- ── Values ──────────────────────────────────────────────── -->
  <Features2
    tagline="Nos valeurs"
    title="Ce en quoi nous croyons"
    subtitle="Chaque décision que nous prenons — de la sélection des producteurs à l'emballage — est guidée par ces principes."
    items={[
      {
        title: 'Transparence totale',
        description:
          'Chaque produit indique sa région d\'origine, sa méthode de transformation et sa composition complète. Aucun ingrédient caché.',
        icon: 'tabler:eye',
      },
      {
        title: 'Commerce équitable',
        description:
          'Nous payons nos producteurs partenaires à un prix juste, au-dessus du marché local, pour valoriser leur savoir-faire et garantir leur pérennité.',
        icon: 'tabler:scale',
      },
      {
        title: 'Qualité sans compromis',
        description:
          'Chaque lot est contrôlé avant expédition. Si un produit ne respecte pas nos standards, il ne part pas. C\'est aussi simple que ça.',
        icon: 'tabler:award',
      },
      {
        title: 'Respect de la nature',
        description:
          'Nos partenaires pratiquent une agriculture raisonnée, sans intrants chimiques, qui préserve les sols et la biodiversité locale.',
        icon: 'tabler:leaf',
      },
      {
        title: 'Enracinés dans la culture',
        description:
          'Les plantes que nous proposons ont une histoire, des usages traditionnels, une place dans la vie des communautés. Nous la racontons à chaque fois.',
        icon: 'tabler:book',
      },
      {
        title: 'Service client humain',
        description:
          'Une question sur un produit ? Un problème de livraison ? Vous parlez à une personne réelle, pas à un chatbot. Toujours.',
        icon: 'tabler:message-heart',
      },
    ]}
  />

  <!-- ── Team/Founder ────────────────────────────────────────── -->
  <Content
    tagline="Le fondateur"
    title="Une passion transmise de génération en génération"
    content={`
      <p>Nadey Naturel a été fondé par quelqu'un qui a grandi en regardant sa famille utiliser les plantes du jardin pour se soigner, se nourrir et prendre soin les uns des autres.</p>
      <p class="mt-4">Après avoir vécu à la croisée des cultures, entre le Bénin et l'Europe, la même question revenait sans cesse : pourquoi est-il si difficile de retrouver ces produits simples et efficaces loin de chez soi ?</p>
      <p class="mt-4">La réponse a été de créer Nadey Naturel — pas seulement une boutique, mais un lien direct entre des terres fertiles du Bénin et des tables de la diaspora partout dans le monde.</p>
    `}
    image={{
      src: 'https://images.unsplash.com/photo-1559827260-dc66d52bef19?w=800&q=80',
      alt: 'Champ de moringa au Bénin',
    }}
    items={[
      {
        title: 'Fondé au Bénin',
        description: 'Une entreprise 100 % béninoise, fière de ses racines et de son terroir.',
        icon: 'tabler:map-pin',
      },
      {
        title: 'Pensé pour la diaspora',
        description: 'Conçu par et pour des personnes qui connaissent ces plantes depuis l\'enfance.',
        icon: 'tabler:heart',
      },
    ]}
  />

  <!-- ── CTA ─────────────────────────────────────────────────── -->
  <CallToAction
    tagline="Rejoignez l'aventure"
    title="Essayez Nadey Naturel"
    subtitle="Découvrez notre gamme de produits naturels et faites le choix d'une santé enracinée dans la tradition."
    actions={[
      { variant: 'primary', text: 'Voir la boutique', href: '/fr/boutique', icon: 'tabler:shopping-cart' },
      { text: 'Nous contacter', href: '/contact' },
    ]}
  />

</Layout>
