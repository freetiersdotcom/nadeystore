---
// src/components/store/CartToast.astro
// Shared toast notification shown after add-to-cart.
// Controlled by showCartToast() exported below — import in page scripts.
// cartUrl should match the locale: /fr/panier or /en/cart.
interface Props {
  cartUrl?: string;
}
const { cartUrl = '/fr/panier' } = Astro.props;
---

<div
  id="cart-toast"
  class="fixed bottom-6 right-6 z-50 bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-700 rounded-xl px-4 py-3 flex items-center gap-3 shadow-xl"
  style="display:none"
  role="status"
  aria-live="polite"
>
  <svg class="w-4 h-4 text-green-500 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
  </svg>
  <div class="min-w-0">
    <p class="text-sm font-medium text-default truncate" data-toast-title></p>
    <p class="text-xs text-muted" data-toast-label>Ajouté au panier</p>
  </div>
  <a
    id="toast-view"
    href={cartUrl}
    class="text-xs font-medium bg-gray-100 dark:bg-slate-700 hover:bg-gray-200 dark:hover:bg-slate-600 px-3 py-1.5 rounded-lg transition-colors flex-shrink-0 text-default"
  >
    Voir le panier
  </a>
</div>

<script>
  // showCartToast is called from product listing and product page scripts.
  // Exported on window so it can be called from inline scripts too.
  window.showCartToast = function(productTitle: string) {
    const toast = document.getElementById('cart-toast');
    if (!toast) return;
    const titleEl = toast.querySelector('[data-toast-title]') as HTMLElement;
    if (titleEl) titleEl.textContent = productTitle;
    toast.style.display = 'flex';
    clearTimeout((toast as any).__timer);
    (toast as any).__timer = setTimeout(() => {
      toast.style.display = 'none';
    }, 3000);
  };

  declare global {
    interface Window {
      showCartToast: (title: string) => void;
    }
  }
</script>
